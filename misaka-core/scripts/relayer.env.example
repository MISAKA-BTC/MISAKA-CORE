# MISAKA relayer local bootstrap environment
#
# Copy this file to a local env file and edit the values before starting the
# relayer. The compose bootstrap script expects the same variable names.
#
# Required by relayer/src/config.rs:
# - RELAYER_NETWORK
# - SOLANA_RPC_URL
# - MISAKA_RPC_URL
# - BRIDGE_PROGRAM_ID
# - RELAYER_KEYPAIR
# - MISAKA_CHAIN_ID
#
# Optional:
# - POLL_INTERVAL
# - PROCESSED_STORE
# - RUST_LOG

RELAYER_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
MISAKA_RPC_URL=http://127.0.0.1:3001
BRIDGE_PROGRAM_ID=MBRDGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RELAYER_KEYPAIR=/keys/relayer.json
MISAKA_CHAIN_ID=2
POLL_INTERVAL=15
PROCESSED_STORE=/data/relayer-processed.json
RUST_LOG=info
