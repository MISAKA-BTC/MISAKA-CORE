# MISAKA node Docker bootstrap environment
#
# IMPORTANT: This file may contain secrets (validator passphrase, API key).
# Set permissions before use:
#   chmod 600 scripts/node.env
#
# Copy this file to scripts/node.env and edit it before starting the node.
# The bootstrap script reads the file, validates the Compose config, and then
# passes it into Docker Compose.
#
# Required:
# - NODE_MODE
# - NODE_CHAIN_ID
# - MISAKA_RPC_API_KEY (required for mainnet; without it, mainnet nodes refuse to start)
#
# Common operator settings:
# - NODE_NAME
# - NODE_VALIDATOR_INDEX
# - NODE_VALIDATORS
# - NODE_VALIDATOR
# - NODE_ADVERTISE_ADDR
# - NODE_SEEDS
# - NODE_PEERS
# - NODE_RPC_PORT
# - NODE_P2P_PORT
# - NODE_LOG_LEVEL
# - NODE_DATA_DIR
# - NODE_DAG_K
# - NODE_DAG_CHECKPOINT_INTERVAL
# - NODE_DAG_MAX_TXS
# - NODE_DAG_MEMPOOL_SIZE
# - NODE_MAX_INBOUND_PEERS
# - NODE_MAX_OUTBOUND_PEERS
#
# NODE_MODE accepts `public`, `hidden`, `seed`, or the loose alias `validator`.
# - public: advertise and accept inbound P2P traffic
# - hidden: full-node style operation without advertising your IP
# - seed: bootstrap node that never produces blocks
# - validator: CLI alias for public mode + NODE_VALIDATOR=true
#
# For multi-validator deployments, keep NODE_VALIDATOR_INDEX and NODE_VALIDATORS
# aligned with the container's ordinal position in the validator set.
#
# The bootstrap script validates the env file before Compose startup:
# - NODE_MODE must be public, hidden, seed, or validator
# - NODE_VALIDATOR=true or NODE_MODE=validator requires a validator passphrase
# - NODE_VALIDATOR_INDEX must stay below NODE_VALIDATORS
# - numeric ports and DAG settings must be integers
#
# Compose defaults are aligned with the example values below so `check` can
# rehearse the same operator surface that `up` will use.
#
# Validator-only secret:
# - MISAKA_VALIDATOR_PASSPHRASE

NODE_NAME=misaka-node-0
NODE_MODE=public
NODE_VALIDATOR=false
NODE_CHAIN_ID=2
NODE_DATA_DIR=/var/lib/misaka
NODE_RPC_PORT=3001
NODE_P2P_PORT=6690
NODE_BLOCK_TIME_SECS=60
NODE_VALIDATOR_INDEX=0
NODE_VALIDATORS=1
NODE_LOG_LEVEL=info
# Faucet: testnet ONLY. Set to 0 on mainnet. Requires "faucet" feature build.
NODE_FAUCET_AMOUNT=0
NODE_FAUCET_COOLDOWN_MS=300000
NODE_ADVERTISE_ADDR=
NODE_OUTBOUND_ONLY=false
NODE_HIDE_MY_IP=false
NODE_PEERS=
NODE_SEEDS=
NODE_MAX_INBOUND_PEERS=32
NODE_MAX_OUTBOUND_PEERS=8
NODE_PROXY=
NODE_DAG_K=18
NODE_DAG_CHECKPOINT_INTERVAL=50
NODE_DAG_MAX_TXS=256
NODE_DAG_MEMPOOL_SIZE=10000
NODE_DAG_RPC_PEERS=
NODE_EXPERIMENTAL_ZK_PATH=false
MISAKA_VALIDATOR_PASSPHRASE=
# RPC API key (required for mainnet; protects submit_tx and bridge endpoints)
MISAKA_RPC_API_KEY=
# Proposer's ML-DSA-65 public key (hex, 1952 bytes = 3904 hex chars)
# Required for coinbase outputs to be spendable
MISAKA_PROPOSER_SPENDING_PUBKEY=
