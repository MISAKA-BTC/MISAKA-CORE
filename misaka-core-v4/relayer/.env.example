# ═══════════════════════════════════════════════════════════════
#  MISAKA Bridge Relayer — Burn & Mint Model
#  Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Network Mode (REQUIRED) ──
# Must be one of: devnet, testnet, mainnet
RELAYER_NETWORK=devnet

# ── Solana Configuration (REQUIRED) ──
# Solana JSON-RPC endpoint
SOLANA_RPC_URL=https://api.devnet.solana.com

# Bridge program ID on Solana (base58 pubkey)
BRIDGE_PROGRAM_ID=BRDGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SPL token mint address for MISAKA tokens on Solana (base58 pubkey)
# This is the mint whose burns are detected and relayed
SOLANA_MISAKA_MINT=MSKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MISAKA Chain Configuration (REQUIRED) ──
# MISAKA chain RPC endpoint
MISAKA_RPC_URL=http://127.0.0.1:26657

# MISAKA chain ID (1 = mainnet, 2 = devnet/testnet)
MISAKA_CHAIN_ID=2

# ── Relayer Identity (REQUIRED) ──
# Path to the relayer's Solana keypair JSON file
RELAYER_KEYPAIR=~/.config/solana/relayer-keypair.json

# ── API Configuration ──
# Port for the HTTP API server (default: 8080)
API_PORT=8080

# Admin secret for protected API endpoints (min 16 chars, REQUIRED)
ADMIN_SECRET=change-me-to-a-strong-secret-at-least-16-chars

# ── Storage ──
# Path to SQLite database file (default: ./relayer-processed.json)
PROCESSED_STORE=./relayer-processed.json

# ── Polling ──
# Poll interval in seconds (default: 15)
POLL_INTERVAL=15

# ── Circuit Breaker ──
# Set to "1" to resume a paused bridge (cleared automatically after resume)
# MISAKA_BRIDGE_RESUME=1
